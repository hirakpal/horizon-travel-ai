# .env.example
OPENROUTER_API_KEY=your_key_here
LANGCHAIN_TRACING_V2=false
MODEL_NAME=openai/gpt-4o-mini

# Optional: enables real-place grounding, real walking distances, and photos/street
# view in the itinerary. Needs Places API (New), Routes API, and Street View Static
# API enabled on the same Google Cloud project/key. The app works fine without it —
# it just falls back to LLM-only itinerary content.
GOOGLE_MAPS_API_KEY=your_key_here
