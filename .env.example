# .env.example
OPENROUTER_API_KEY=your_key_here
LANGCHAIN_TRACING_V2=false
MODEL_NAME=openai/gpt-4o-mini

# Optional: enables real-place grounding, real walking distances, photos/street view,
# and the Home page's live transit delay check. Needs Places API (New), Routes API,
# and Street View Static API enabled on the same Google Cloud project/key. The app
# works fine without it — it just falls back to LLM-only itinerary content, and the
# Home page's live monitoring panel skips the transit check.
GOOGLE_MAPS_API_KEY=your_key_here

# No env var needed: the Home page's live weather and crowd-estimate checks use
# Open-Meteo, a free keyless API, so they work even without GOOGLE_MAPS_API_KEY.

# Optional: where the user accounts SQLite file lives. Defaults to data/horizon_users.db.
HORIZON_DB_PATH=data/horizon_users.db

# Optional: enables real email delivery of password-reset codes via SMTP. Without
# these, the reset code is shown directly in the UI (labeled "DEV MODE") instead.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com

# Optional: enables real SMS delivery of password-reset codes via Twilio. Without
# these, the reset code is shown directly in the UI (labeled "DEV MODE") instead.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15550001111
